# Notion API key (create an integration at https://www.notion.so/my-integrations)
NOTION_API_KEY=secret_...

# Database ID for the Prisoversikt table
# (grab from the Notion URL: https://notion.so/<workspace>/<DATABASE_ID>?v=...)
NOTION_PRISOVERSIKT_DATABASE_ID=...

# Shopify Admin API credentials (optional — enables price/kg and price/portion)
# Create an app in the Dev Dashboard: https://dev.shopify.com
# Then run:  python shopify_oauth.py --shop YOUR.myshopify.com \
#              --client-id ... --client-secret ... --save-env
# Scopes needed: read_products, read_orders
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Skio API token (optional — enables the Skio purchase-order table in the
# Ordrestatus tab). Generate in: Skio dashboard → API & Integrations → API.
# Only the value goes here — the `API ` prefix required by Skio is added by
# skio_client.py automatically.
#   SKIO_GRAPHQL_URL is optional and only needed if Skio rotates the endpoint;
#   defaults to https://graphql.skio.com/v1/graphql
SKIO_API_TOKEN=
# SKIO_GRAPHQL_URL=

# Gordon Delivery — used by gordon_exporter.py to forward Shopify orders.
# Per the Gordon docs, "test mode" is the staging environment, selected by
# the base URL + credentials you use.
# Get Client ID/Secret from Gordon Last Mile (GLMP): Account → API Credentials.
#   test:       uses https://backend.staging.gordondelivery.com (hard-coded)
#   production: requires GORDON_PRODUCTION_BASE_URL (Gordon provides on request)
GORDON_ENV=test
GORDON_CLIENT_ID=
GORDON_CLIENT_SECRET=
GORDON_DELIVERY_GROUP=
GORDON_PRODUCTION_BASE_URL=
